{
  "name": "@diogoparente/cc-manager",
  "version": "1.0.0",
  "description": "Switch between Claude Code API configs in one command — multiple providers, keys, and model overrides without editing settings by hand",
  "main": "./dist/bin/cc-manager.js",
  "bin": {
    "cc-manager": "dist/bin/cc-manager.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/bin/cc-manager.ts",
    "test": "vitest",
    "prepublishOnly": "npm run build && npm test"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "claude",
    "claude-code",
    "profile",
    "cli",
    "ai",
    "anthropic",
    "openai",
    "google",
    "xai",
    "mistral"
  ],
  "license": "MIT",
  "author": "diogoparente",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/diogoparente/cc-manager.git"
  },
  "homepage": "https://github.com/diogoparente/cc-manager#readme",
  "bugs": {
    "url": "https://github.com/diogoparente/cc-manager/issues"
  },
  "dependencies": {
    "chalk": "^5.6.2",
    "commander": "^14.0.3",
    "inquirer": "^13.4.2"
  },
  "devDependencies": {
    "@types/inquirer": "^9.0.9",
    "@types/node": "^25.6.0",
    "tempy": "^3.2.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  }
}
